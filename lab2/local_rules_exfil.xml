<?xml version="1.0" encoding="UTF-8"?>
<group name="local,exfiltration,">
  <!-- Regla para detección de actividad sospechosa fuera de horario laboral -->
  <rule id="100002" level="12">
    <if_sid>5715</if_sid>
    <hour>22-23,0-5</hour>
    <same_source_ip />
    <description>Login SSH exitoso fuera del horario laboral desde $(srcip) - posible exfiltración potencial</description>
    <mitre>
      <id>T1048</id>
    </mitre>
    <group>exfiltration,</group>
  </rule>

  <!-- Regla para detección de archivos grandes (simplificada) -->
  <rule id="100003" level="10">
    <category>ossec</category>
    <decoded_as>ossec</decoded_as>
    <description>Archivo grande modificado o accedido - $(file)</description>
    <group>exfiltration,</group>
  </rule>
</group>
