<?xml version="1.0" encoding="UTF-8"?>
<group name="local,syslog,sshd,">

  <!-- Regla para detección de brute force SSH (5 intentos fallidos en 10 segundos) -->
  <!-- Basada en la regla 5710 de Wazuh -->
  <rule id="100001" level="10" frequency="5" timeframe="10">
    <if_matched_sid>5710</if_matched_sid>
    <same_source_ip />
    <description>Brute force SSH detectado: $(srcip) ha realizado $(frequency) intentos fallidos en $(timeframe) segundos.</description>
    <mitre>
      <id>T1110</id> <!-- Brute Force -->
    </mitre>
    <group>authentication_failed,gdpr_IV_32.2,pci_dss_10.2.4,pci_dss_10.2.5,gpg13_7.1,hipaa_164.312.b,nist_800_53_AU.14,nist_800_53_AC.7,nist_800_53_SI.4,tsc_CC6.1,tsc_CC6.8,tsc_CC7.2,tsc_CC7.3,</group>
  </rule>

</group>
